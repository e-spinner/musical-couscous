{
  "name": "architecture-desktop",
  "version": "0.1.0",
  "description": "Architecture desktop app with Electron frontend and Flask scheduling backend.",
  "author": "Architecture Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:win-portable",
    "build:win": "npm run build:win-portable",
    "build:linux": "npm run build:linux-portable",
    "build:win-portable": "electron-builder --win portable --x64",
    "build:linux-portable": "electron-builder --linux AppImage --x64"
  },
  "build": {
    "directories": {
      "output": "builds"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/architecture-backend",
        "to": "backend/architecture-backend"
      }
    ],
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  }
}
