{
  "name": "architecture-desktop",
  "version": "0.1.0",
  "description": "Architecture desktop app with Electron frontend and Flask scheduling backend.",
  "author": "Architecture Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "directories": {
      "output": "builds"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/architecture-backend.exe",
        "to": "backend/architecture-backend.exe"
      }
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  }
}
